<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!-- Runs the JavaScript that builds the Aforo usage event payload from
     Apigee context variables. The output is stored in flow variable
     'aforo.eventPayload' for the ServiceCallout policy to send. -->
<Javascript name="AforoMeteringBuildEvent" timeLimit="2000">
    <DisplayName>Aforo Metering - Build Event Payload</DisplayName>
    <ResourceURL>jsc://aforo-metering.js</ResourceURL>
</Javascript>
