<!--
    Aforo Pre-Flight Quota Check Policy Fragment for Azure APIM

    Runs in the inbound policy (before proxying to backend).
    Calls usage-ingestor /api/v1/quota/check synchronously.
    Fail-open: returns ALLOW if check times out or fails.

    Named values required:
      aforo-preflight-enabled:    "true" | "false"
      aforo-preflight-url:        Usage ingestor quota check URL
      aforo-preflight-timeout-ms: Max wait (default: 50)
      aforo-preflight-fallback:   "ALLOW" (default) or "DENY"
      aforo-api-key:              Aforo API key
      aforo-tenant-id:            Tenant identifier
-->
<fragment>
    <inbound>
        <choose>
            <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;aforo-preflight-enabled&quot;, &quot;false&quot;) == &quot;true&quot;)">
                <send-request mode="new" response-variable-name="preflightResponse" timeout="1" ignore-error="true">
                    <set-url>@(context.Variables.GetValueOrDefault&lt;string&gt;("aforo-preflight-url"))</set-url>
                    <set-method>POST</set-method>
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-header name="X-Tenant-Id" exists-action="override">
                        <value>@(context.Variables.GetValueOrDefault&lt;string&gt;("aforo-tenant-id"))</value>
                    </set-header>
                    <set-header name="Authorization" exists-action="override">
                        <value>@($"Bearer {context.Variables.GetValueOrDefault&lt;string&gt;("aforo-api-key")}")</value>
                    </set-header>
                    <set-body><![CDATA[@{
                        var customerId = context.Subscription?.Key ?? context.User?.Id ?? "";
                        var body = new JObject();
                        body["customerId"] = customerId;
                        return body.ToString(Newtonsoft.Json.Formatting.None);
                    }]]></set-body>
                </send-request>

                <!-- Parse response and enforce decision -->
                <choose>
                    <when condition="@(context.Variables.ContainsKey(&quot;preflightResponse&quot;))">
                        <set-variable name="preflightDecision" value="@{
                            try {
                                var response = ((IResponse)context.Variables[&quot;preflightResponse&quot;]);
                                if (response.StatusCode != 200) return &quot;ALLOW&quot;;
                                var body = response.Body.As&lt;JObject&gt;();
                                var data = body[&quot;data&quot;] ?? body;
                                return data[&quot;decision&quot;]?.ToString() ?? &quot;ALLOW&quot;;
                            } catch {
                                return context.Variables.GetValueOrDefault&lt;string&gt;(&quot;aforo-preflight-fallback&quot;, &quot;ALLOW&quot;);
                            }
                        }" />

                        <choose>
                            <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;preflightDecision&quot;) == &quot;DENY&quot;)">
                                <return-response>
                                    <set-status code="429" reason="Too Many Requests" />
                                    <set-header name="Content-Type" exists-action="override">
                                        <value>application/json</value>
                                    </set-header>
                                    <set-header name="Retry-After" exists-action="override">
                                        <value>60</value>
                                    </set-header>
                                    <set-body>{"message": "Rate limit exceeded"}</set-body>
                                </return-response>
                            </when>
                            <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;preflightDecision&quot;) == &quot;WARN&quot;)">
                                <set-header name="X-RateLimit-Warning" exists-action="override">
                                    <value>approaching-limit</value>
                                </set-header>
                            </when>
                        </choose>
                    </when>
                </choose>
            </when>
        </choose>
    </inbound>
</fragment>
