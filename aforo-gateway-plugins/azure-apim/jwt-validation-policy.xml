<!--
  Aforo JWT Validation Policy for Azure API Management

  Validates RS256 JWTs issued by Aforo's OAuth token endpoint.
  Must be placed in the <inbound> section BEFORE the existing outbound metering fragment.

  Prerequisites — create these Named Values in your APIM instance:
    aforo-jwks-uri      — Aforo JWKS endpoint URL
                          e.g. https://auth.smartai.com/.well-known/jwks.json
    aforo-jwt-issuer    — Expected issuer
                          e.g. https://auth.aforo.ai

  Usage in APIM policy (add to the inbound section of your API policy):
    <inbound>
        <base />
        <include-fragment fragment-id="aforo-jwt-validation" />
    </inbound>
    <outbound>
        <base />
        <include-fragment fragment-id="aforo-metering" />
    </outbound>

  Claims extracted and forwarded as upstream headers:
    X-Customer-Id  — customer_id claim (falls back to sub)
    X-Tenant-Id    — tenant_id claim
    X-Key-Id       — key_id claim
    X-Scopes       — scopes claim (space-separated or array joined)
    X-Environment  — environment claim ("live" or "sandbox")

  On validation failure: returns 401 Unauthorized with a JSON body.
-->
<fragment>
    <inbound>
        <!--
          validate-jwt performs RS256 signature verification using the JWKS URI.
          APIM fetches and caches the JWKS automatically; the cache is refreshed
          when a `kid` is not found (key rotation scenario).

          clock-skew-seconds: 30s tolerance to handle slight server time drift.
          require-expiration-time: enforces the `exp` claim.
          require-signed-tokens: rejects unsigned (alg=none) tokens.
        -->
        <validate-jwt
            header-name="Authorization"
            failed-validation-httpcode="401"
            failed-validation-error-message="Unauthorized — invalid or missing Aforo JWT"
            require-expiration-time="true"
            require-signed-tokens="true"
            clock-skew-seconds="30"
            output-token-variable-name="aforo-jwt">

            <!-- JWKS-based RS256 key resolution -->
            <openid-config url="{{aforo-jwks-uri}}" />

            <!-- Issuer validation -->
            <issuers>
                <issuer>{{aforo-jwt-issuer}}</issuer>
            </issuers>

            <!-- Optional: restrict to specific audiences if Aforo sets the aud claim -->
            <!-- <audiences><audience>https://api.aforo.ai</audience></audiences> -->
        </validate-jwt>

        <!--
          Extract JWT claims from the validated token variable and set them as
          upstream request headers. All headers are overwritten (exists-action="override")
          so clients cannot forge identity headers by sending them directly.

          The C# expressions decode the JWT payload inline using base64url decoding
          and Newtonsoft.Json (available in all APIM tiers).
        -->
        <set-variable name="aforo-jwt-payload" value="@{
            var token = (string)context.Variables.GetValueOrDefault(
                            "aforo-jwt",
                            context.Request.Headers.GetValueOrDefault("Authorization", "")
                                .Replace("Bearer ", "").Replace("bearer ", ""));
            var parts = token.Split('.');
            if (parts.Length != 3) return null;
            var padded = parts[1].PadRight(parts[1].Length + (4 - parts[1].Length % 4) % 4, '=')
                                 .Replace('-', '+').Replace('_', '/');
            try {
                var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(padded));
                return Newtonsoft.Json.Linq.JObject.Parse(json);
            } catch { return null; }
        }"/>

        <set-header name="X-Customer-Id" exists-action="override">
            <value>@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables["aforo-jwt-payload"];
                if (payload == null) return "";
                return payload["customer_id"]?.ToString()
                    ?? payload["sub"]?.ToString()
                    ?? "";
            }</value>
        </set-header>

        <set-header name="X-Tenant-Id" exists-action="override">
            <value>@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables["aforo-jwt-payload"];
                return payload?["tenant_id"]?.ToString() ?? "";
            }</value>
        </set-header>

        <set-header name="X-Key-Id" exists-action="override">
            <value>@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables["aforo-jwt-payload"];
                return payload?["key_id"]?.ToString() ?? "";
            }</value>
        </set-header>

        <set-header name="X-Scopes" exists-action="override">
            <value>@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables["aforo-jwt-payload"];
                if (payload == null) return "";
                var scopes = payload["scopes"];
                if (scopes == null) return "";
                if (scopes.Type == Newtonsoft.Json.Linq.JTokenType.Array) {
                    return string.Join(" ", scopes.ToObject<string[]>());
                }
                return scopes.ToString();
            }</value>
        </set-header>

        <set-header name="X-Environment" exists-action="override">
            <value>@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables["aforo-jwt-payload"];
                return payload?["environment"]?.ToString() ?? "live";
            }</value>
        </set-header>

        <!--
          jti Blocklist Check
          Azure APIM's validate-jwt does not natively check a Redis blocklist.
          Two options:
            A) Use send-request to call the org-service internal endpoint synchronously.
               This adds ~5-10ms latency but is accurate in real time.
            B) Accept the window between token revocation and APIM cache expiry
               (~the validate-jwt cache TTL, typically 5-60 minutes).

          Option A is shown below — comment it out to use Option B.
          The endpoint is org-service's internal token-check API:
            GET /internal/v1/auth/token-check?jti={jti}&keyId={keyId}
            Response: { "revoked": true|false }
        -->
        <send-request mode="new" response-variable-name="aforo-jti-check" timeout="2" ignore-error="true">
            <set-url>@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables["aforo-jwt-payload"];
                var jti   = payload?["jti"]?.ToString()    ?? "";
                var keyId = payload?["key_id"]?.ToString() ?? "";
                return string.Format(
                    "http://org-service:8086/internal/v1/auth/token-check?jti={0}&keyId={1}",
                    Uri.EscapeDataString(jti),
                    Uri.EscapeDataString(keyId));
            }</set-url>
            <set-method>GET</set-method>
            <set-header name="X-Internal-Call" exists-action="override">
                <value>apim</value>
            </set-header>
        </send-request>

        <choose>
            <when condition="@{
                var response = (IResponse)context.Variables.GetValueOrDefault(
                                   "aforo-jti-check", null);
                if (response == null) return false;  // fail-open on timeout/error
                if (response.StatusCode != 200) return false;
                try {
                    var body = Newtonsoft.Json.Linq.JObject.Parse(
                                   response.Body.As<string>());
                    return body["revoked"]?.ToObject<bool>() == true;
                } catch { return false; }
            }">
                <return-response>
                    <set-status code="401" reason="Unauthorized"/>
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>{
                        "error": "invalid_token",
                        "error_description": "Token has been revoked"
                    }</set-body>
                </return-response>
            </when>
        </choose>
    </inbound>
</fragment>
