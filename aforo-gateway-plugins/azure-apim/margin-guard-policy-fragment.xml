<!--
    Aforo Margin Guard Pre-Flight Check — Azure API Management Policy Fragment

    Calls pricing-service /internal/v1/margin-guard/quick-check to determine
    whether a request should be allowed, throttled (L2), or blocked (L3).

    Fail-open: if the pricing-service call fails or times out, the request
    proceeds. Fail-CLOSED on identity: if customerId can't be resolved from
    an authenticated source, the margin-guard check is SKIPPED (treated as
    anonymous / public endpoint) — never fall back to reading a
    client-settable request header.

    Prerequisites:
      - aforo-jwt-validation policy fragment MUST be applied before this
        fragment. It sets context.Variables["aforo-jwt-payload"] (a JObject
        containing the verified JWT claims).
      - Named value: aforo-margin-guard-url (pricing-service base URL)
      - Named value: aforo-margin-guard-enabled ("true" to enable)
      - Named value: aforo-tenant-id (tenant identifier — admin-pinned fallback)

    Usage: Include in inbound section, AFTER jwt-validation-policy.xml.
    <include-fragment fragment-id="aforo-margin-guard" />

    Security history:
      v1.x read X-Customer-Id and X-Tenant-Id from the request as
      primary sources (client-settable, therefore spoofable). Closed
      2026-04-23 — now sources exclusively from:
        customerId: JWT customer_id claim, else APIM subscription id
        tenantId:   JWT tenant_id claim, else admin-pinned Named Value
-->
<fragment>
    <choose>
        <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;aforo-margin-guard-enabled&quot;, &quot;false&quot;) == &quot;true&quot;)">
            <!--
                Resolve customer / tenant identity from authenticated sources only.
                Primary: JWT claims (cryptographically verified by jwt-validation-policy).
                Fallback for customer: APIM subscription id (bound to the verified subscription key).
                Fallback for tenant: admin-pinned Named Value (not client-settable).
                NEVER read X-Customer-Id / X-Tenant-Id from the request headers.
            -->
            <set-variable name="mgCustomerId" value="@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables.GetValueOrDefault&lt;object&gt;(&quot;aforo-jwt-payload&quot;, null);
                var fromJwt = payload == null ? null
                    : (payload[&quot;customer_id&quot;]?.ToString() ?? payload[&quot;sub&quot;]?.ToString());
                if (!string.IsNullOrEmpty(fromJwt)) return fromJwt;
                // Fallback: APIM-managed subscription id (set by subscription-key validation).
                return context.Subscription != null ? context.Subscription.Id : &quot;&quot;;
            }" />
            <set-variable name="mgTenantId" value="@{
                var payload = (Newtonsoft.Json.Linq.JObject)context.Variables.GetValueOrDefault&lt;object&gt;(&quot;aforo-jwt-payload&quot;, null);
                var fromJwt = payload?[&quot;tenant_id&quot;]?.ToString();
                if (!string.IsNullOrEmpty(fromJwt)) return fromJwt;
                // Fallback: admin-pinned Named Value.
                return context.Variables.GetValueOrDefault&lt;string&gt;(&quot;aforo-tenant-id&quot;, &quot;&quot;);
            }" />

            <choose>
                <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;mgCustomerId&quot;, &quot;&quot;) != &quot;&quot; &amp;&amp; context.Variables.GetValueOrDefault&lt;string&gt;(&quot;mgTenantId&quot;, &quot;&quot;) != &quot;&quot;)">

                    <!-- Check cache first (Azure APIM internal cache, 30s TTL) -->
                    <cache-lookup-value key="@($&quot;mg:{context.Variables[&quot;mgTenantId&quot;]}:{context.Variables[&quot;mgCustomerId&quot;]}&quot;)" variable-name="mgCachedResult" />

                    <choose>
                        <when condition="@(context.Variables.ContainsKey(&quot;mgCachedResult&quot;))">
                            <!-- Use cached result -->
                            <set-variable name="mgResult" value="@((string)context.Variables[&quot;mgCachedResult&quot;])" />
                        </when>
                        <otherwise>
                            <!-- Call pricing-service quick-check -->
                            <send-request mode="new" response-variable-name="mgResponse" timeout="1" ignore-error="true">
                                <set-url>@($"{context.Variables["aforo-margin-guard-url"]}/internal/v1/margin-guard/quick-check?tenantId={context.Variables["mgTenantId"]}&amp;scopeType=CUSTOMER&amp;scopeId={context.Variables["mgCustomerId"]}")</set-url>
                                <set-method>GET</set-method>
                                <set-header name="Content-Type" exists-action="override">
                                    <value>application/json</value>
                                </set-header>
                                <set-header name="X-Tenant-Id" exists-action="override">
                                    <value>@((string)context.Variables["mgTenantId"])</value>
                                </set-header>
                            </send-request>

                            <choose>
                                <when condition="@(context.Variables.ContainsKey(&quot;mgResponse&quot;) &amp;&amp; ((IResponse)context.Variables[&quot;mgResponse&quot;]).StatusCode == 200)">
                                    <set-variable name="mgResult" value="@(((IResponse)context.Variables[&quot;mgResponse&quot;]).Body.As&lt;string&gt;())" />
                                    <!-- Cache for 30 seconds -->
                                    <cache-store-value key="@($&quot;mg:{context.Variables[&quot;mgTenantId&quot;]}:{context.Variables[&quot;mgCustomerId&quot;]}&quot;)" value="@((string)context.Variables[&quot;mgResult&quot;])" duration="30" />
                                </when>
                                <otherwise>
                                    <!-- Fail-open: pricing-service unreachable, allow request -->
                                    <set-variable name="mgResult" value='{"allowed":true,"level":"NONE"}' />
                                </otherwise>
                            </choose>
                        </otherwise>
                    </choose>

                    <!-- Enforce based on result -->
                    <choose>
                        <!-- L3 BLOCK -->
                        <when condition="@{
                            var json = JObject.Parse((string)context.Variables[&quot;mgResult&quot;]);
                            return json.Value&lt;bool&gt;(&quot;allowed&quot;) == false &amp;&amp; json.Value&lt;string&gt;(&quot;level&quot;) == &quot;L3_BLOCK&quot;;
                        }">
                            <return-response>
                                <set-status code="429" reason="Margin Guard - Blocked" />
                                <set-header name="Content-Type" exists-action="override">
                                    <value>application/json</value>
                                </set-header>
                                <set-header name="X-Margin-Guard" exists-action="override">
                                    <value>blocked</value>
                                </set-header>
                                <set-header name="X-Margin-Guard-Level" exists-action="override">
                                    <value>L3</value>
                                </set-header>
                                <set-header name="Retry-After" exists-action="override">
                                    <value><![CDATA[@{
                                        var json = JObject.Parse((string)context.Variables["mgResult"]);
                                        return json.Value<int?>("retryAfterSeconds")?.ToString() ?? "1800";
                                    }]]></value>
                                </set-header>
                                <set-body><![CDATA[@{
                                    var json = JObject.Parse((string)context.Variables["mgResult"]);
                                    var retryAfter = json.Value<int?>("retryAfterSeconds") ?? 1800;
                                    return new JObject(
                                        new JProperty("error", new JObject(
                                            new JProperty("code", "SERVICE_RESTRICTED_MARGIN"),
                                            new JProperty("message", json.Value<string>("message") ?? "Service restricted due to margin constraints."),
                                            new JProperty("retryAfterSeconds", retryAfter),
                                            new JProperty("supportUrl", "/portal/support")
                                        ))
                                    ).ToString();
                                }]]></set-body>
                            </return-response>
                        </when>

                        <!-- L2 THROTTLE (probabilistic) -->
                        <when condition="@{
                            var json = JObject.Parse((string)context.Variables[&quot;mgResult&quot;]);
                            if (json.Value&lt;bool&gt;(&quot;allowed&quot;) == false &amp;&amp; json.Value&lt;string&gt;(&quot;level&quot;) == &quot;L2_THROTTLE&quot;) {
                                var throttleRate = json.Value&lt;int?&gt;(&quot;throttleRate&quot;) ?? 50;
                                var roll = new Random().Next(100);
                                return roll &gt;= throttleRate;
                            }
                            return false;
                        }">
                            <return-response>
                                <set-status code="429" reason="Margin Guard - Throttled" />
                                <set-header name="Content-Type" exists-action="override">
                                    <value>application/json</value>
                                </set-header>
                                <set-header name="X-Margin-Guard" exists-action="override">
                                    <value>throttled</value>
                                </set-header>
                                <set-header name="X-Margin-Guard-Level" exists-action="override">
                                    <value>L2</value>
                                </set-header>
                                <set-header name="Retry-After" exists-action="override">
                                    <value>60</value>
                                </set-header>
                                <set-body>{"error":{"code":"RATE_LIMITED_MARGIN","message":"Rate limited due to margin constraints. Please retry.","retryAfterSeconds":60,"dashboardUrl":"/portal/cost-explorer"}}</set-body>
                            </return-response>
                        </when>
                    </choose>
                </when>
            </choose>
        </when>
    </choose>
</fragment>
