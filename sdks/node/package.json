{
  "name": "@aforo/metering",
  "version": "1.0.0",
  "description": "Aforo usage metering SDK — track API usage events with batching, retry, and framework middleware",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./middleware/express": {
      "import": "./dist/esm/middleware/express.js",
      "require": "./dist/cjs/middleware/express.js",
      "types": "./dist/types/middleware/express.d.ts"
    },
    "./middleware/fastify": {
      "import": "./dist/esm/middleware/fastify.js",
      "require": "./dist/cjs/middleware/fastify.js",
      "types": "./dist/types/middleware/fastify.d.ts"
    },
    "./middleware/koa": {
      "import": "./dist/esm/middleware/koa.js",
      "require": "./dist/cjs/middleware/koa.js",
      "types": "./dist/types/middleware/koa.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@types/express": ">=4.0.0",
    "@types/koa": ">=2.0.0",
    "fastify": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@types/express": { "optional": true },
    "@types/koa": { "optional": true },
    "fastify": { "optional": true }
  },
  "keywords": ["aforo", "metering", "usage", "billing", "api", "middleware", "express", "fastify", "koa"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aforoai/aforo-metering-node.git"
  }
}
